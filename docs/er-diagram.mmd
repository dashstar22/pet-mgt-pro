%%{init: {
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Microsoft YaHei, SimHei, Arial",
    "primaryTextColor": "#263238",
    "lineColor": "#78909C",
    "entityBkg": "#FAFAFA",
    "entityBorder": "#90A4AE",
    "attributeBackgroundColorOdd": "#FFFFFF",
    "attributeBackgroundColorEven": "#F5F7FA"
  }
}}%%

erDiagram
    direction TB

    %% ========== 用户与角色 ==========
    user {
        BIGINT id PK "用户ID"
        VARCHAR username UK "用户名"
        VARCHAR password "密码"
        VARCHAR email "邮箱"
        VARCHAR avatar_url "头像"
        TINYINT enabled "状态"
        DATETIME created_at "创建时间"
        DATETIME updated_at "更新时间"
    }

    role {
        BIGINT id PK "角色ID"
        VARCHAR role_name UK "角色名称"
    }

    user_role {
        BIGINT user_id PK,FK "用户ID"
        BIGINT role_id PK,FK "角色ID"
    }

    %% ========== 宠物基础信息 ==========
    pet_breed {
        BIGINT id PK "品种ID"
        VARCHAR breed_name "品种名称"
        VARCHAR pet_type "宠物类型"
        TEXT description "品种描述"
        DATETIME created_at "创建时间"
    }

    pet {
        BIGINT id PK "宠物ID"
        VARCHAR name "宠物名称"
        BIGINT breed_id FK "品种ID"
        VARCHAR gender "性别"
        INT age "年龄(月)"
        DECIMAL weight "体重"
        VARCHAR health_status "健康状态"
        VARCHAR vaccine_status "疫苗状态"
        VARCHAR sterilization_status "绝育状态"
        TEXT personality "性格描述"
        TEXT adoption_requirement "领养要求"
        VARCHAR status "领养状态"
        BIGINT created_by FK "发布者ID"
        DATETIME created_at "创建时间"
        DATETIME updated_at "更新时间"
    }

    pet_image {
        BIGINT id PK "图片ID"
        BIGINT pet_id FK "宠物ID"
        VARCHAR image_url "图片路径"
        TINYINT is_cover "是否封面"
        DATETIME created_at "上传时间"
    }

    %% ========== 领养申请 ==========
    adoption_application {
        BIGINT id PK "申请ID"
        BIGINT pet_id FK "宠物ID"
        BIGINT user_id FK "申请人ID"
        VARCHAR phone "联系电话"
        VARCHAR address "联系地址"
        TEXT experience "养宠经验"
        VARCHAR accompany_time "陪伴时间"
        TEXT reason "领养理由"
        VARCHAR status "审核状态"
        TEXT review_comment "审核意见"
        BIGINT reviewed_by FK "审核人ID"
        DATETIME reviewed_at "审核时间"
        DATETIME created_at "申请时间"
    }

    %% ========== AI 功能记录 ==========
    ai_match_record {
        BIGINT id PK "匹配记录ID"
        BIGINT user_id FK "用户ID"
        TEXT preference_text "用户偏好"
        TEXT result_text "匹配结果"
        BIGINT recommended_pet_id FK "推荐宠物ID"
        INT match_score "匹配分数"
        DATETIME created_at "匹配时间"
    }

    ai_review_record {
        BIGINT id PK "审核记录ID"
        BIGINT application_id FK "申请ID"
        TEXT result_text "AI审核结果"
        INT score "审核评分"
        VARCHAR suggestion "审核建议"
        DATETIME created_at "审核时间"
    }

    %% ========== 表关系定义 ==========
    user ||--o{ user_role : "拥有角色"
    role ||--o{ user_role : "分配给用户"

    user ||--o{ pet : "发布宠物"
    pet_breed ||--o{ pet : "包含宠物"

    pet ||--o{ pet_image : "拥有图片"

    user ||--o{ adoption_application : "提交申请"
    pet ||--o{ adoption_application : "被申请"
    user ||--o{ adoption_application : "审核申请"

    user ||--o{ ai_match_record : "发起匹配"
    pet ||--o{ ai_match_record : "被推荐"

    adoption_application ||--o{ ai_review_record : "生成审核记录"